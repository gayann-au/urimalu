# Copy this file to .env and fill in the values for your environment.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Supabase project credentials (Supabase dashboard -> Project Settings -> API).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Identity Services client id for Sign in with Google.
# This value is public (it ships to the browser), so it is safe to commit here.
# It must also be added as an authorised client id on the Google provider in
# Supabase (Authentication -> Providers -> Google).
VITE_GOOGLE_CLIENT_ID=541950730198-68sm6p07dccp9lka6ukh2avkie2r8vfj.apps.googleusercontent.com

# Web Push public VAPID key. Safe to expose to the browser (it identifies the
# app to the push service). Generate a keypair once and paste the PUBLIC half
# here; the PRIVATE half goes ONLY into the Supabase Edge Function secrets,
# never into any committed file.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
